# CHANAKYA backend configuration (copy to backend/.env for local dev).
# All values have safe defaults; nothing here is a secret. Real secrets (e.g.
# an LLM API key in later phases) must ONLY ever be provided via the real
# environment — never committed.

# TCP listen address for the API server.
CHANAKYA_ADDR=:8080

# Path to the SQLite system-of-record file (created on first run).
CHANAKYA_DB_PATH=./chanakya.db

# Comma-separated list of browser origins allowed by CORS (the web app).
CHANAKYA_CORS_ORIGINS=http://localhost:3000

# --- Regulation Compiler (Phase 2) ---
# Anthropic API key. Leave UNSET to use the deterministic offline extractor
# (default; no key, fully reproducible). Set it to use the real LLM extractor —
# output is validated against the same strict schema either way.
# CHANAKYA_LLM_API_KEY=
# Model id for the Anthropic extractor (defaults to claude-opus-4-8).
# CHANAKYA_LLM_MODEL=claude-opus-4-8

# --- Sign-off (Phase 6) ---
# Ed25519 signing key seed file (created on first run, gitignored). This is the
# demo signing authority; in production the reviewer's own key/HSM would sign.
# CHANAKYA_SIGNING_KEY_PATH=./chanakya_signing.key
# Or provide the seed directly as base64 (32 bytes) instead of a file:
# CHANAKYA_SIGNING_KEY_B64=
